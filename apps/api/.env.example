PORT=3001
NODE_ENV=development

# ── IRAQ TV API Configuration ─────────────────────────────────────────────────
APP_NAME=IRAQ TV
APP_NAME_AR=إيراق تيفي

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# ── Database (production) ─────────────────────────────────────────────────────
# DATABASE_URL=postgresql://iraqtv:password@localhost:5432/iraqtv

# ── Redis (production) ────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── EPG ───────────────────────────────────────────────────────────────────────
# EPG_SOURCE_URL=https://your-epg-provider.com/xmltv.xml

# ── Subscriptions ─────────────────────────────────────────────────────────────
# PAYMENT_GATEWAY=stripe
# STRIPE_SECRET_KEY=sk_test_...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
